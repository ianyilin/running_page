{
  "name": "ianyilin-running-page",
  "description": "Personal Strava running log for ianyilin.github.io/running/",
  "version": "1.0.0",
  "author": "Yi Lin",
  "packageManager": "pnpm@8.9.0+sha256.8f5264ad1d100da11a6add6bb8a94c6f1e913f9e9261b2a551fabefad2ec0fec",
  "dependencies": {
    "@mapbox/polyline": "^1.2.0",
    "@math.gl/web-mercator": "^4.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "gcoord": "^0.3.2",
    "maplibre-gl": "^3.6.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-map-gl": "^7.1.6",
    "react-router-dom": "^6.15.0",
    "vite": "^7.1.2",
    "vite-plugin-svgr": "^4.3.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "data:clean": "rm -f run_page/data.db src/static/activities.json",
    "data:download:strava": ".venv/bin/python run_page/strava_env_sync.py",
    "build": "vite build",
    "develop": "vite dev",
    "dev": "vite dev",
    "serve": "vite serve",
    "lint": "eslint src --ext .ts,.tsx --fix",
    "check": "prettier --check \"src/main.tsx\" \"src/**/*.{css,module.css,json,ts,tsx}\" \"*.{yaml,yml,json,ts}\" \".github/**/*.yml\"",
    "format": "prettier --write \"src/main.tsx\" \"src/**/*.{css,module.css,json,ts,tsx}\" \"*.{yaml,yml,json,ts}\" \".github/**/*.yml\"",
    "ci": "pnpm run format && pnpm run lint && pnpm run build"
  },
  "engineStrict": true,
  "browserslist": "defaults, not ie 11",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ianyilin/running_page"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.32.0",
    "@tailwindcss/vite": "^4.1.11",
    "@types/geojson": "^7946.0.14",
    "@types/mapbox__polyline": "^1.0.2",
    "@types/node": "^24.2.1",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^16.3.0",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.13",
    "tailwindcss": "^4.1.10",
    "typescript": "^5.2.2"
  },
  "pnpm": {
    "overrides": {
      "@types/node": "^24.2.1"
    }
  }
}
